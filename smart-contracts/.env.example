# ── Blockchain Provider ────────────────────────────────────────
# Obtenir sur https://infura.io ou https://alchemy.com
ETHEREUM_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_PROJECT_ID

# ── Deployer Wallet ────────────────────────────────────────────
# Clé privée du wallet qui déploie les contrats (JAMAIS le wallet principal)
# Doit avoir des Sepolia ETH (gratuit sur https://sepoliafaucet.com)
DEPLOYER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# ── Etherscan Verification ─────────────────────────────────────
# Pour vérifier les contrats sur Etherscan (https://etherscan.io/myapikey)
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY

# ── Après déploiement (rempli automatiquement par deploy.js) ───
ESCROW_CONTRACT_ADDRESS=
REPUTATION_CONTRACT_ADDRESS=
LITIGATION_CONTRACT_ADDRESS=
CHAIN_ID=11155111
