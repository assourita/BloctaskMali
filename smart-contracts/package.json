{
  "name": "blocktask-smart-contracts",
  "version": "1.0.0",
  "description": "BlockTask Smart Contracts - Escrow, Reputation, Litigation",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "setup:env": "node scripts/setup-env.js",
    "init:sepolia-wallet": "node scripts/init-sepolia-wallet.js",
    "deploy:local": "hardhat run scripts/deploy.js --network localhost",
    "deploy:sepolia": "hardhat run scripts/deploy.js --network sepolia",
    "deploy:sepolia:full": "npm run compile && npm run deploy:sepolia && npm run export-abi && node scripts/apply-config.js sepolia",
    "apply:config": "node scripts/apply-config.js sepolia",
    "apply:remix": "node scripts/apply-config.js remix-vm",
    "apply:hardhat": "node scripts/apply-config.js hardhat",
    "remix:addresses": "node scripts/remix-set-addresses.js",
    "node": "hardhat node",
    "verify": "hardhat run scripts/verify.js --network sepolia",
    "export-abi": "hardhat run scripts/export-abi.js"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "@openzeppelin/contracts": "^4.9.3",
    "hardhat": "^2.19.0"
  },
  "dependencies": {
    "dotenv": "^16.3.1"
  }
}
