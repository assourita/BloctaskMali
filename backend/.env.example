# Django Settings
DEBUG=True
SECRET_KEY=your-secret-key-change-this-in-production
# Variables supplémentaires pour Render
ALLOWED_HOSTS=
CORS_ALLOWED_ORIGINS=
FRONTEND_URL=http://localhost:4200

# PostgreSQL Database
DB_NAME=blocktask
DB_USER=blocktask_user
DB_PASSWORD=your-secure-password
DB_HOST=localhost
DB_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379/0

# ── Blockchain (Sepolia testnet — Mali phase 1) ──
# Créez une clé gratuite sur https://www.alchemy.com ou https://infura.io
ETHEREUM_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
CHAIN_ID=11155111

# Smart Contract Addresses (après déploiement Hardhat/Remix)
ESCROW_CONTRACT_ADDRESS=
REPUTATION_CONTRACT_ADDRESS=
LITIGATION_CONTRACT_ADDRESS=

# Relayer optionnel (validation admin on-chain)
BLOCKCHAIN_RELAYER_PRIVATE_KEY=
BLOCKCHAIN_RELAYER_ADDRESS=

# ── Mobile Money Mali ──
# SANDBOX=true : simulation sans vrai débit (OTP test : 1234). Aucun frais, idéal dev/démo/mémoire.
# SANDBOX=false : APIs réelles Orange/Moov (compte marchand requis, vrais transferts).
MOBILE_MONEY_SANDBOX=true
ORANGE_MONEY_API_URL=
ORANGE_MONEY_MERCHANT_ID=
ORANGE_MONEY_API_KEY=
MOOV_MONEY_API_URL=
MOOV_MONEY_MERCHANT_ID=
MOOV_MONEY_API_KEY=

# Email (SendGrid, Resend ou SMTP)
# Priorité : Resend > SendGrid > SMTP Django
RESEND_API_KEY=
SENDGRID_API_KEY=
DEFAULT_FROM_EMAIL=noreply@blocktask.ml
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
REQUIRE_EMAIL_VERIFICATION=True

# Google OAuth — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=

# Firebase (pour notifications push)
FIREBASE_API_KEY=
FIREBASE_PROJECT_ID=

# Twilio (pour SMS Mali +223)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
