---
title: Figure 3.5 — Diagramme de classes (cœur métier)
---
classDiagram
    class User {
        +UUID id
        +String email
        +Enum user_type
        +Enum kyc_status
        +String nina
        +String wallet_address
        +String country
        +Boolean gps_tracking_enabled
    }

    class ProviderProfile {
        +Float reputation_score
        +Decimal deposit_balance
        +Decimal deposit_locked
        +Enum level
    }

    class Mission {
        +UUID id
        +String title
        +Decimal budget
        +Enum status
        +Decimal required_deposit
        +Boolean deposit_paid
        +Int mission_contract_id
        +String blockchain_status
        +DateTime deposit_deadline
    }

    class MissionApplication {
        +Enum status
        +Decimal proposed_price
        +String message
    }

    class Payment {
        +Decimal amount
        +Decimal platform_fee
        +Decimal provider_amount
        +Enum status
        +String mobile_operator
    }

    class ProviderDeposit {
        +Decimal amount
        +Enum status
        +Boolean is_dynamic
    }

    class MissionProof {
        +Enum proof_type
        +Enum verification_status
        +String file_url
    }

    class GPSLocation {
        +Float latitude
        +Float longitude
        +DateTime timestamp
    }

    class Dispute {
        +Enum status
        +Enum decision
        +Decimal refund_amount
    }

    class ReputationScore {
        +Float overall_score
        +Float success_rate
        +Float avg_rating
    }

    class EscrowTransaction {
        +Enum transaction_type
        +String tx_hash
        +Int block_number
    }

    User "1" --> "0..1" ProviderProfile
    User "1" --> "*" Mission : client
    User "1" --> "*" Mission : provider
    Mission "1" --> "*" MissionApplication
    Mission "1" --> "0..1" Payment
    Mission "1" --> "*" MissionProof
    Mission "1" --> "*" GPSLocation
    Mission "1" --> "0..1" Dispute
    Mission "1" --> "*" EscrowTransaction
    User "1" --> "0..1" ReputationScore
    User "1" --> "*" ProviderDeposit
    MissionApplication --> User : provider
