# Backend local — téléphone sur le même Wi‑Fi que le PC
# Utilisez l'IP affichée par Metro (ex. 192.168.1.123), pas 127.0.0.1
# Lancez le backend : python manage.py runserver 0.0.0.0:8000
# EXPO_PUBLIC_API_URL=http://192.168.1.123:8000/api

# Google OAuth — Client Web (Angular + backend)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# Optionnel Expo Go : clients natifs Google Cloud (recommandé)
# iOS  → type Application iOS, bundle ID : host.exp.Exponent
# Android → type Application Android, package : host.exp.exponent
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# Redirect URI à ajouter au client Web (voir logs Metro [BlockTask] Google redirectUri)
# Exemples Expo Go :
#   host.exp.Exponent:/oauthredirect
#   host.exp.exponent:/oauthredirect

# Google Maps (suivi GPS / carte) — même clé Maps JavaScript API que le frontend web
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=
