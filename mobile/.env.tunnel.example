# Copiez ce fichier vers .env quand vous utilisez le tunnel ngrok.
# 1. Terminal 1 : cd backend && python manage.py runserver 0.0.0.0:8000
# 2. Créez un token : https://dashboard.ngrok.com/get-started/your-authtoken
# 3. Ajoutez NGROK_AUTH_TOKEN ci-dessous
# 4. Terminal 2 : cd mobile && npm run tunnel:backend
# 5. Collez l'URL ngrok affichée dans EXPO_PUBLIC_API_URL (avec /api à la fin)
# Terminal mobile (même Wi‑Fi) :
#   npm run start:lan
#
# Terminal mobile (tunnel ngrok, hors Wi‑Fi) :
#   npm run start:tunnel

NGROK_AUTH_TOKEN=votre_token_ngrok_ici
EXPO_PUBLIC_API_URL=https://VOTRE-URL-NGROK.ngrok-free.app/api
